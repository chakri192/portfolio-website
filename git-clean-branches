#!/usr/bin/env bash
#
# git-clean-branches
#
# Scans every git repo (one level deep) inside a parent folder and cleans up
# local branches that are safe to remove:
#   1. Local branches already merged into main/master
#   2. Local branches whose remote-tracking branch no longer exists ("gone")
#
# Never touches main/master, and never force-deletes anything with unmerged
# commits unless you pass -f.
#
# Usage:
#   git-clean-branches              # preview only, scans current directory
#   git-clean-branches [path]       # preview only, scans given path
#   git-clean-branches -y           # actually delete what's found (current dir)
#   git-clean-branches [path] -y    # actually delete what's found
#   git-clean-branches [path] -y -f # delete, force (-D) even if unmerged
#
# If [path] is omitted, defaults to the current directory.

set -u

ROOT="."
APPLY=false
FORCE=false

for arg in "$@"; do
  case "$arg" in
    -y) APPLY=true ;;
    -f) FORCE=true ;;
    -*) ;;
    *) ROOT="$arg" ;;
  esac
done

if [ ! -d "$ROOT" ]; then
  echo "Error: '$ROOT' is not a directory."
  exit 1
fi

DELETE_FLAG="-d"
if $FORCE; then
  DELETE_FLAG="-D"
fi

echo "Scanning repos under: $ROOT"
if $APPLY; then
  echo "Mode: APPLY (branches will be deleted, flag: $DELETE_FLAG)"
else
  echo "Mode: PREVIEW (no changes will be made — pass -y to actually delete)"
fi
echo ""

total_deleted=0

for dir in "$ROOT"/*/; do
  [ -d "$dir/.git" ] || continue

  repo_name="$(basename "$dir")"
  echo "=== $repo_name ==="

  (
    cd "$dir" || exit

    # figure out the default branch (main or master)
    default_branch=""
    if git show-ref --verify --quiet refs/heads/main; then
      default_branch="main"
    elif git show-ref --verify --quiet refs/heads/master; then
      default_branch="master"
    fi

    git fetch -p --quiet 2>/dev/null

    # 1. local branches merged into default branch
    merged=""
    if [ -n "$default_branch" ]; then
      merged=$(git branch --merged "$default_branch" \
        | grep -v -e "^\*" -e " main$" -e " master$" -e "^  main$" -e "^  master$" \
        | sed 's/^[* ] //')
    fi

    # 2. local branches whose remote tracking branch is gone
    gone=$(git branch -vv | awk '/: gone]/{print $1}' | sed 's/^\*//')

    # combine + dedupe
    candidates=$(printf "%s\n%s\n" "$merged" "$gone" | sed '/^$/d' | sort -u)

    if [ -z "$candidates" ]; then
      echo "  nothing to clean"
    else
      while IFS= read -r branch; do
        [ -z "$branch" ] && continue
        if $APPLY; then
          if git branch "$DELETE_FLAG" "$branch" 2>/tmp/git_clean_err; then
            echo "  deleted: $branch"
          else
            echo "  skipped (not fully merged, use -f to force): $branch"
          fi
        else
          echo "  would delete: $branch"
        fi
      done <<< "$candidates"
    fi
  )
  echo ""
done

echo "Done."
if ! $APPLY; then
  echo "This was a preview. Re-run with -y to actually delete these branches."
fi
